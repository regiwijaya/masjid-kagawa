generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Admin {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  role      String   @default("admin")
  createdAt DateTime @default(now())
}

model Announcement {
  id          Int      @id @default(autoincrement())
  title       String
  category    String?
  date        DateTime
  description String?
  imageUrl    String?
  isPublished Boolean  @default(true)
  isFeatured  Boolean  @default(false)
  createdBy   Int?
  updatedBy   Int?
  createdAt   DateTime @default(now())
}

model Activity {
  id          Int      @id @default(autoincrement())
  title       String
  category    String?  @default("Kegiatan")
  date        DateTime
  startTime   String?
  endTime     String?
  location    String?
  description String?
  imageUrl    String?
  isPublished Boolean  @default(true)
  createdBy   Int?
  updatedBy   Int?
  createdAt   DateTime @default(now())
}

model Kajian {
  id          Int      @id @default(autoincrement())
  title       String
  category    String?  @default("Lainnya")
  ustadz      String?
  date        DateTime
  time        String?
  location    String?  @default("Masjid Kagawa")
  description String?
  imageUrl    String?
  isPublished Boolean  @default(true)
  isFeatured  Boolean  @default(false)
  createdBy   Int?
  updatedBy   Int?
  createdAt   DateTime @default(now())
}

model Post {
  id          Int      @id @default(autoincrement())
  title       String
  slug        String   @unique
  excerpt     String?
  content     String?
  imageUrl    String?
  category    String?  @default("Artikel")
  author      String?  @default("Admin Masjid Kagawa")
  isPublished Boolean  @default(true)
  isFeatured  Boolean  @default(false)
  createdBy   Int?
  updatedBy   Int?
  createdAt   DateTime @default(now())
}

model AboutSetting {
  id                Int      @id @default(autoincrement())
  heroTitle         String?
  heroSubtitle      String?
  heroImageUrl      String?
  historyTitle      String?
  historyText       String?
  historyImageUrl   String?
  visionTitle       String?
  visionText        String?
  missionTitle      String?
  missionItems      Json?
  leaders           Json?
  footerDescription String?
  address           String?
  email             String?
  phone             String?
  mapEmbedUrl       String?
  imamDuty          String?
  muadzinDuty       String?
  social            Json?
  updatedBy         Int?
  createdAt         DateTime @default(now())
}

model DonationSetting {
  id                         Int      @id @default(autoincrement())
  bankJapanName              String?
  bankJapanAccountName       String?
  bankJapanAccountNumber     String?
  bankJapanBranch            String?
  bankIndonesiaName          String?
  bankIndonesiaAccountName   String?
  bankIndonesiaAccountNumber String?
  bankIndonesiaBranch        String?
  qrisImageUrl               String?
  donationNote               String?
  confirmationText           String?
  confirmationLink           String?
  updatedBy                  Int?
  createdAt                  DateTime @default(now())
}

model IqamahSetting {
  id        Int      @id @default(autoincrement())
  subuh     String?
  zuhur     String?
  asar      String?
  maghrib   String?
  isya      String?
  createdAt DateTime @default(now())
}